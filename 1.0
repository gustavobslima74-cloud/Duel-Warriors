--// ABA WHITELIST
task.spawn(function()
    while true do
        if tabs.Whitelist.Visible then
            for _, v in pairs(tabs.Whitelist:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer then
                    local b = Instance.new("TextButton", tabs.Whitelist); b.Size = UDim2.new(1, 0, 0, 30)
                    b.Text = p.DisplayName; b.BackgroundColor3 = isWhitelisted(p) and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(40, 40, 40)
                    b.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", b)
                    b.MouseButton1Click:Connect(function()
                        whitelist[p.UserId] = not whitelist[p.UserId]
                        b.BackgroundColor3 = whitelist[p.UserId] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(40, 40, 40)
                    end)
                end
            end
        end
        task.wait(3)
    end
end)

--// SISTEMA DE GESTO (SWIPE DOWN) PARA ABRIR O MENU
local touchStart = nil
UserInputService.TouchStarted:Connect(function(touch, gameProcessed)
    if gameProcessed then return end
    touchStart = touch.Position
end)

UserInputService.TouchEnded:Connect(function(touch, gameProcessed)
    if not getgenv().SwipeMenu or not touchStart then return end
    
    local drop = touch.Position - touchStart
    local screen = workspace.CurrentCamera.ViewportSize
    
    -- Verifica se o dedo desceu mais de 80 pixels e não foi pro lado
    if drop.Y > 80 and math.abs(drop.X) < 60 then
        -- Verifica se o movimento começou no TOPO (Top 30%) e no CENTRO (entre 30% e 70% da largura)
        if touchStart.Y < (screen.Y * 0.3) and touchStart.X > (screen.X * 0.3) and touchStart.X < (screen.X * 0.7) then
            main.Visible = not main.Visible
            if main.Visible then
                main.Position = UDim2.new(0.5, -140, 0.5, -220)
            end
        end
    end
    touchStart = nil
end)

--// LOOPS PRINCIPAIS E FÍSICA
RunService.Stepped:Connect(function()
    -- RGB e Bypass Invisível
    local rgb = Color3.fromHSV(tick() % 5 / 5, 1, 1)
    title.TextColor3 = rgb; mainStroke.Color = rgb; floatStroke.Color = rgb
    
    local isRec = getgenv().RecordingMode
    openBtn.BackgroundTransparency = isRec and 1 or 0
    openBtn.TextTransparency = isRec and 1 or 0
    floatPanel.BackgroundTransparency = isRec and 1 or 0
    floatStroke.Transparency = isRec and 1 or 0
    moveHandle.BackgroundTransparency = isRec and 1 or 0
    moveHandle.TextTransparency = isRec and 1 or 0
    
    for _, btn in pairs(FloatingButtonsList) do
        btn.BackgroundTransparency = isRec and 1 or 0
        btn.TextTransparency = isRec and 1 or 0
        if not isRec then
            btn.BackgroundColor3 = getgenv()[btn.Name] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(30, 30, 30)
        end
    end
    FloatingButtonsList[1].Name = "AutoAttack"
    FloatingButtonsList[2].Name = "TeleportOnAttack"
    FloatingButtonsList[3].Name = "StickMode"
    FloatingButtonsList[4].Name = "CharAimLock"

    local myChar = LocalPlayer.Character
    local myHum = myChar and myChar:FindFirstChild("Humanoid")
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    
    if myHum then myHum.WalkSpeed = getgenv().WalkSpeedValue end

    local target, dist = getClosest()
    local eRoot = target and target.Character and target.Character:FindFirstChild("HumanoidRootPart")

    if getgenv().StickMode and myRoot and eRoot then
        local goal = eRoot.CFrame * CFrame.new(0, 0, getgenv().StickDistance)
        myRoot.CFrame = myRoot.CFrame:Lerp(goal, 1 - (getgenv().StickSmoothness/100))
    end
    
    if getgenv().CharAimLock and myRoot and eRoot then
        local bg = myRoot:FindFirstChild("DW_AimGyro")
        if not bg then
            bg = Instance.new("BodyGyro")
            bg.Name = "DW_AimGyro"
            bg.MaxTorque = Vector3.new(0, math.huge, 0)
            bg.P = 500000
            bg.Parent = myRoot
        end
        bg.CFrame = CFrame.lookAt(myRoot.Position, Vector3.new(eRoot.Position.X, myRoot.Position.Y, eRoot.Position.Z))
    else
        if myRoot then
            local bg = myRoot:FindFirstChild("DW_AimGyro")
            if bg then bg:Destroy() end
        end
    end
    
    if getgenv().MyHealth and myHum then
        myHealthLbl.Visible = true
        local hp = math.floor(myHum.Health)
        local max = math.floor(myHum.MaxHealth)
        myHealthLbl.Text = "MEU HP: " .. hp .. " / " .. max
        if hp > (max * 0.6) then myHealthLbl.TextColor3 = Color3.fromRGB(0, 255, 0)
        elseif hp > (max * 0.3) then myHealthLbl.TextColor3 = Color3.fromRGB(255, 255, 0)
        else myHealthLbl.TextColor3 = Color3.fromRGB(255, 0, 0) end
    else
        myHealthLbl.Visible = false
    end
    
    if getgenv().AntiFling and myHum then
        myHum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        myHum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        if myHum:GetState() == Enum.HumanoidStateType.Ragdoll then myHum:ChangeState(Enum.HumanoidStateType.GettingUp) end
    end
end)

UserInputService.JumpRequest:Connect(function()
    if getgenv().InfiniteJump and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid:ChangeState("Jumping")
    end
end)

task.spawn(function()
    while true do
        if getgenv().AutoAttack then
            local target, dist = getClosest()
            if target and dist <= attackRange then
                local r = getRemote()
                if r then
                    r:FireServer({Key = "TouchATK", State = Enum.UserInputState.Begin})
                    task.wait(0.05)
                    r:FireServer({Key = "TouchATK", State = Enum.UserInputState.End})
                end
            end
        end
        task.wait(0.1)
    end
end)

task.spawn(function()
    while true do
        local btn = LocalPlayer.PlayerGui:FindFirstChild("ATK", true)
        if btn and btn:IsA("GuiButton") and not btn:FindFirstChild("TpHook") then
            Instance.new("BoolValue", btn).Name = "TpHook"
            btn.MouseButton1Down:Connect(function()
                if getgenv().TeleportOnAttack then
                    local target = getClosest()
                    if target and target.Character then
                        LocalPlayer.Character.HumanoidRootPart.CFrame = target.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, getgenv().StickDistance)
                    end
                end
            end)
        end
        task.wait(1)
    end
end)

RunService.RenderStepped:Connect(function()
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local target = getClosest()
    
    local plrsDist = {}
    if myRoot then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                local d = (myRoot.Position - p.Character.HumanoidRootPart.Position).Magnitude
                table.insert(plrsDist, {plr = p, dist = d})
            end
        end
        table.sort(plrsDist, function(a,b) return a.dist < b.dist end)
    end
    
    local top5 = {}
    for i=1, math.min(5, #plrsDist) do top5[plrsDist[i].plr] = true end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") then
            local char = p.Character
            
            local hl = char:FindFirstChild("DW_Highlight") or Instance.new("Highlight", char)
            hl.Name = "DW_Highlight"; hl.FillTransparency = 0.5
            
            if isWhitelisted(p) and getgenv().HighlightFriendly then 
                hl.FillColor = Color3.new(0,1,0); hl.Enabled = true
            elseif p == target and getgenv().HighlightEnemy then 
                hl.FillColor = Color3.new(1,0,0); hl.Enabled = true
            else 
                hl.Enabled = false 
            end
            
            local bbGui = char.HumanoidRootPart:FindFirstChild("DW_HealthESP")
            if getgenv().HealthESP and top5[p] then
                if not bbGui then
                    bbGui = Instance.new("BillboardGui", char.HumanoidRootPart)
                    bbGui.Name = "DW_HealthESP"
                    bbGui.Size = UDim2.new(0, 80, 0, 30)
                    bbGui.StudsOffset = Vector3.new(2.5, -1.5, 0)
                    bbGui.AlwaysOnTop = true
                    
                    local txt = Instance.new("TextLabel", bbGui)
                    txt.Size = UDim2.new(1, 0, 1, 0)
                    txt.BackgroundTransparency = 1
                    txt.Font = Enum.Font.GothamBold
                    txt.TextSize = 11
                    txt.TextStrokeTransparency = 0
                end
                
                local hp = math.floor(char.Humanoid.Health)
                local maxHp = math.floor(char.Humanoid.MaxHealth)
                bbGui.TextLabel.Text = hp .. " / " .. maxHp
                
                if hp > (maxHp * 0.6) then bbGui.TextLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
                elseif hp > (maxHp * 0.3) then bbGui.TextLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
                else bbGui.TextLabel.TextColor3 = Color3.fromRGB(255, 0, 0) end
            else
                if bbGui then bbGui:Destroy() end
            end
        end
    end
end)
