layout.Padding = UDim.new(0, 8)
layout.SortOrder = Enum.SortOrder.LayoutOrder

--// SISTEMA DE SINCRONIZAÇÃO DE BOTÕES
local UIElements = {}

local function toggleVar(varName)
    getgenv()[varName] = not getgenv()[varName]
    local state = getgenv()[varName]
    
    local ui = UIElements[varName]
    if ui then
        if ui.MenuBtn then
            ui.MenuBtn.Text = ui.BaseText .. (state and " [ON]" or " [OFF]")
            ui.MenuBtn.BackgroundColor3 = state and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(30, 30, 30)
        end
        if ui.FloatBtn then
            ui.FloatBtn.BackgroundColor3 = state and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(30, 30, 30)
        end
    end
end

--// CRIADOR DE BOTÕES COMBINADOS
local function createCombinedToggle(text, emoji, varName)
    UIElements[varName] = { BaseText = text }

    -- Cria no Menu
    local mBtn = Instance.new("TextButton", container)
    mBtn.Size = UDim2.new(1, -10, 0, 40)
    mBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    mBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    mBtn.Font = Enum.Font.GothamBold
    mBtn.TextSize = 14
    mBtn.Text = text .. " [OFF]"
    Instance.new("UICorner", mBtn).CornerRadius = UDim.new(0, 8)
    UIElements[varName].MenuBtn = mBtn

    mBtn.MouseButton1Click:Connect(function() toggleVar(varName) end)

    -- Cria no Flutuante (Tamanho reduzido)
    if emoji then
        local fBtn = Instance.new("TextButton", floatPanel)
        fBtn.Size = UDim2.new(0, 35, 0, 35) -- Botões menores e mais otimizados
        fBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        fBtn.Text = emoji
        fBtn.TextScaled = true
        Instance.new("UICorner", fBtn).CornerRadius = UDim.new(1, 0)
        UIElements[varName].FloatBtn = fBtn

        fBtn.MouseButton1Click:Connect(function() toggleVar(varName) end)
    end
end

-- Toggle do Painel Flutuante
local function createPanelToggle()
    local btn = Instance.new("TextButton", container)
    btn.Size = UDim2.new(1, -10, 0, 40)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 14
    btn.Text = "Mostrar Painel Flutuante [OFF]"
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

    btn.MouseButton1Click:Connect(function()
        getgenv().FloatingPanelVisible = not getgenv().FloatingPanelVisible
        local state = getgenv().FloatingPanelVisible
        btn.Text = "Mostrar Painel Flutuante" .. (state and " [ON]" or " [OFF]")
        btn.BackgroundColor3 = state and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(30, 30, 30)
        floatPanel.Visible = state
    end)
end

--// ADICIONANDO AS FUNÇÕES
createCombinedToggle("Auto Attack", "🤺", "AutoAttack")
createCombinedToggle("Teleport no Ataque", "⚡", "TeleportOnAttack")
createCombinedToggle("Grudar no Alvo", "⚔️", "StickMode")
createPanelToggle()

--// SEÇÃO WHITELIST
local wlTitle = Instance.new("TextLabel", container)
wlTitle.Size = UDim2.new(1, 0, 0, 25)
wlTitle.BackgroundTransparency = 1
wlTitle.Text = "--- Whitelist (Aliados) ---"
wlTitle.TextColor3 = Color3.fromRGB(200, 200, 200)
wlTitle.Font = Enum.Font.Gotham

local wlFrame = Instance.new("Frame", container)
wlFrame.Size = UDim2.new(1, -10, 0, 100)
wlFrame.BackgroundTransparency = 1

local wlList = Instance.new("ScrollingFrame", wlFrame)
wlList.Size = UDim2.new(1, 0, 1, 0)
wlList.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
wlList.ScrollBarThickness = 3
Instance.new("UICorner", wlList).CornerRadius = UDim.new(0, 6)
local wlLayout = Instance.new("UIListLayout", wlList)

local function updateWhitelist()
    for _,v in pairs(wlList:GetChildren()) do
        if v:IsA("TextButton") then v:Destroy() end
    end

    for _,plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local btn = Instance.new("TextButton", wlList)
            btn.Size = UDim2.new(1, 0, 0, 30)
            btn.Text = plr.DisplayName
            btn.Font = Enum.Font.Gotham
            btn.TextSize = 14
            btn.TextColor3 = Color3.new(1, 1, 1)
            btn.BackgroundColor3 = isWhitelisted(plr) and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(40, 40, 40)

            btn.MouseButton1Click:Connect(function()
                whitelist[plr.UserId] = not whitelist[plr.UserId]
                btn.BackgroundColor3 = whitelist[plr.UserId] and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(40, 40, 40)
            end)
        end
    end
    wlList.CanvasSize = UDim2.new(0, 0, 0, wlLayout.AbsoluteContentSize.Y)
    container.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 10)
end

task.spawn(function()
    while true do
        updateWhitelist()
        task.wait(4)
    end
end)

--// RGB LOOP
RunService.RenderStepped:Connect(function()
    local hue = tick() % 5 / 5
    local rgb = Color3.fromHSV(hue, 1, 1)
    
    title.TextColor3 = rgb
    mainStroke.Color = rgb
    floatStroke.Color = rgb
end)

--// HIGHLIGHT (ESP) E LÓGICA DE GRUDAR AUTOMÁTICO
RunService.Heartbeat:Connect(function()
    local closest, dist = getClosest()

    if getgenv().StickMode and closest and closest.Character then
        local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        local enemyRoot = closest.Character:FindFirstChild("HumanoidRootPart")
        
        if myRoot and enemyRoot then
            myRoot.CFrame = enemyRoot.CFrame * CFrame.new(0, 0, 3) 
        end
    end

    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local hl = plr.Character:FindFirstChild("DW_Highlight")
            if not hl then
                hl = Instance.new("Highlight", plr.Character)
                hl.Name = "DW_Highlight"
                hl.FillTransparency = 0.6
                hl.OutlineTransparency = 0.2
            end

            if isWhitelisted(plr) then
                hl.FillColor = Color3.fromRGB(0, 255, 0)
                hl.Enabled = true
            elseif plr == closest then
                hl.FillColor = Color3.fromRGB(255, 0, 0)
                hl.Enabled = true
            else
                hl.Enabled = false
            end
        end
    end
end)

--// AUTO ATTACK LOOP
task.spawn(function()
    while true do
        if getgenv().AutoAttack then
            local target, dist = getClosest()
            if target and dist <= attackRange then
                local remote = getRemote()
                if remote then
                    remote:FireServer({Key = "TouchATK", State = Enum.UserInputState.Begin})
                    task.wait(0.05)
                    remote:FireServer({Key = "TouchATK", State = Enum.UserInputState.End})
                end
            end
        end
        task.wait(0.15)
    end
end)

--// TELEPORT NO ATAQUE
task.spawn(function()
    while true do
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        
        if playerGui then
            local mobileScr = playerGui:FindFirstChild("MobileScr", true)
            local atkBtn = mobileScr and mobileScr:FindFirstChild("ATK", true)

            if atkBtn and not atkBtn:FindFirstChild("TeleportHook") then
                local hook = Instance.new("BoolValue", atkBtn)
                hook.Name = "TeleportHook"

                atkBtn.MouseButton1Down:Connect(function()
                    if getgenv().TeleportOnAttack then
                        local target, dist = getClosest()
                        
                        if target and target.Character then
                            local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                            local enemyRoot = target.Character:FindFirstChild("HumanoidRootPart")

                            if myRoot and enemyRoot then
                                myRoot.CFrame = enemyRoot.CFrame * CFrame.new(0, 0, 3)
                            end
                        end
                    end
                end)
            end
        end
        task.wait(1)
    end
end)
