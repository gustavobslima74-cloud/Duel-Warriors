local lp = game:GetService("Players").LocalPlayer
print("🔍 Iniciando Espião de Combo...")

for _, elemento in pairs(lp.PlayerGui:GetDescendants()) do
    if elemento:IsA("Frame") or elemento:IsA("ImageLabel") then
        elemento.Changed:Connect(function(propriedade)
            -- Se o quadrado mudar de cor, transparência ou tamanho ao atacar, ele avisa!
            if propriedade == "BackgroundColor3" or propriedade == "BackgroundTransparency" or propriedade == "ImageColor3" then
                print("⚠️ ACHEI UMA MUDANÇA! Nome:", elemento.Name, "| Pasta Pai:", elemento.Parent.Name)
            end
        end)
    end
end
