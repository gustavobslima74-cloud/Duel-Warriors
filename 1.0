local function createFloatBtn(emoji, varName)
    local b = Instance.new("TextButton", floatPanel)
    b.Size = UDim2.new(0, 35, 0, 35); b.Text = emoji; b.TextScaled = true; b.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Instance.new("UICorner", b, {CornerRadius = UDim.new(0.5, 0)}) 
    
    b.MouseButton1Click:Connect(function() getgenv()[varName] = not getgenv()[varName] end)
    RunService.RenderStepped:Connect(function()
        b.BackgroundColor3 = getgenv()[varName] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(30, 30, 30)
    end)
end

createFloatBtn("🤺", "AutoAttack"); createFloatBtn("⚡", "TeleportOnAttack"); createFloatBtn("⚔️", "StickMode")

--// LOOPS PRINCIPAIS
local lastRollTime = 0

RunService.Stepped:Connect(function()
    -- RGB
    local rgb = Color3.fromHSV(tick() % 5 / 5, 1, 1)
    title.TextColor3 = rgb; mainStroke.Color = rgb; floatStroke.Color = rgb
    
    local myChar = LocalPlayer.Character
    local myHum = myChar and myChar:FindFirstChild("Humanoid")
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    
    -- Speed Force
    if myHum then myHum.WalkSpeed = getgenv().WalkSpeedValue end

    local target, dist = getClosest()
    local eRoot = target and target.Character and target.Character:FindFirstChild("HumanoidRootPart")

    -- Grudar Normal
    if getgenv().StickMode and myRoot and eRoot and not getgenv().FlingPlayer then
        local goal = eRoot.CFrame * CFrame.new(0, 0, getgenv().StickDistance)
        myRoot.CFrame = myRoot.CFrame:Lerp(goal, 1 - (getgenv().StickSmoothness/100))
    end
    
    -- Fling Player (Prioridade sobre o Grudar normal)
    if getgenv().FlingPlayer and myRoot and eRoot then
        -- Acelera absurdamente a rotação e teletransporta para dentro do inimigo
        myRoot.RotVelocity = Vector3.new(0, 50000, 0)
        myRoot.Velocity = Vector3.new(0, 0, 0)
        myRoot.CFrame = eRoot.CFrame
    end
    
    -- Auto Parry (ROLL Tático)
    if getgenv().AutoParry and target and dist < 8 then
        -- Simula recarga do botão ROLL pra não espamar (1 segundo)
        if tick() - lastRollTime > 1.5 then
            local rollBtn = LocalPlayer.PlayerGui:FindFirstChild("ROLL", true)
            if rollBtn and rollBtn:IsA("GuiButton") then
                -- Aciona o botão na tela simulando o toque
                for _, conn in pairs(getconnections(rollBtn.MouseButton1Down)) do
                    conn:Fire()
                end
                lastRollTime = tick()
            end
        end
    end
    
    -- Anti Ragdoll
    if getgenv().AntiFling and myHum then
        myHum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        myHum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        if myHum:GetState() == Enum.HumanoidStateType.Ragdoll then myHum:ChangeState(Enum.HumanoidStateType.GettingUp) end
    end
end)

-- Pulo Infinito
UserInputService.JumpRequest:Connect(function()
    if getgenv().InfiniteJump and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid:ChangeState("Jumping")
    end
end)

-- Auto Attack
task.spawn(function()
    while true do
        if getgenv().AutoAttack then
            local target, dist = getClosest()
            if target and dist <= attackRange then
                local r = getRemote()
                if r then
                    r:FireServer({Key = "TouchATK", State = Enum.UserInputState.Begin})
                    task.wait(0.05)
                    r:FireServer({Key = "TouchATK", State = Enum.UserInputState.End})
                end
            end
        end
        task.wait(0.1)
    end
end)

-- Teleport no Ataque (Hook)
task.spawn(function()
    while true do
        local btn = LocalPlayer.PlayerGui:FindFirstChild("ATK", true)
        if btn and btn:IsA("GuiButton") and not btn:FindFirstChild("TpHook") then
            Instance.new("BoolValue", btn).Name = "TpHook"
            btn.MouseButton1Down:Connect(function()
                if getgenv().TeleportOnAttack then
                    local target = getClosest()
                    if target and target.Character then
                        LocalPlayer.Character.HumanoidRootPart.CFrame = target.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, getgenv().StickDistance)
                    end
                end
            end)
        end
        task.wait(1)
    end
end)

-- Highlights & Health ESP Numerico
RunService.RenderStepped:Connect(function()
    local target = getClosest()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") and p.Character:FindFirstChild("Humanoid") then
            local char = p.Character
            
            -- Lógica do Highlight (ESP de Cor)
            local hl = char:FindFirstChild("DW_Highlight") or Instance.new("Highlight", char)
            hl.Name = "DW_Highlight"; hl.FillTransparency = 0.5
            if isWhitelisted(p) then hl.FillColor = Color3.new(0,1,0); hl.Enabled = true
            elseif p == target then hl.FillColor = Color3.new(1,0,0); hl.Enabled = true
            else hl.Enabled = false end
            
            -- Lógica do Health ESP (Números Flutuantes)
            local bbGui = char.Head:FindFirstChild("DW_HealthESP")
            if getgenv().HealthESP then
                if not bbGui then
                    bbGui = Instance.new("BillboardGui", char.Head)
                    bbGui.Name = "DW_HealthESP"
                    bbGui.Size = UDim2.new(0, 100, 0, 40)
                    bbGui.StudsOffset = Vector3.new(0, 2, 0)
                    bbGui.AlwaysOnTop = true
                    
                    local txt = Instance.new("TextLabel", bbGui)
                    txt.Size = UDim2.new(1, 0, 1, 0)
                    txt.BackgroundTransparency = 1
                    txt.Font = Enum.Font.GothamBold
                    txt.TextSize = 14
                    txt.TextStrokeTransparency = 0
                end
                
                local hp = math.floor(char.Humanoid.Health)
                local maxHp = math.floor(char.Humanoid.MaxHealth)
                bbGui.TextLabel.Text = "[ " .. hp .. " / " .. maxHp .. " ]"
                
                -- Muda cor dependendo da vida
                if hp > (maxHp * 0.6) then
                    bbGui.TextLabel.TextColor3 = Color3.fromRGB(0, 255, 0) -- Verde
                elseif hp > (maxHp * 0.3) then
                    bbGui.TextLabel.TextColor3 = Color3.fromRGB(255, 255, 0) -- Amarelo
                else
                    bbGui.TextLabel.TextColor3 = Color3.fromRGB(255, 0, 0) -- Vermelho
                end
            else
                if bbGui then bbGui:Destroy() end
            end
        end
    end
end)
