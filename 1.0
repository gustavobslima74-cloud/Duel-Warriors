local lp = game:GetService("Players").LocalPlayer
print("🔍 Iniciando Espião Avançado de Combo...")

-- Vigia coisas que já existem na tela
for _, elemento in pairs(lp.PlayerGui:GetDescendants()) do
    if elemento:IsA("GuiObject") then
        elemento.Changed:Connect(function(propriedade)
            if propriedade == "Visible" or propriedade == "Size" or propriedade == "Image" or propriedade == "ImageRectOffset" then
                print("⚠️ ALTERADO (" .. propriedade .. "):", elemento.Name, "| Pasta Pai:", elemento.Parent and elemento.Parent.Name or "Nenhuma")
            end
        end)
    end
end

-- Vigia coisas que são criadas/destruídas na hora do ataque
lp.PlayerGui.DescendantAdded:Connect(function(elemento)
    if elemento:IsA("GuiObject") then
        print("🆕 CRIADO NA TELA:", elemento.Name, "| Pasta Pai:", elemento.Parent and elemento.Parent.Name or "Nenhuma")
    end
end)
