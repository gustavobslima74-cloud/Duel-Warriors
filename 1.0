local function createTabBtn(text, targetTab)
    local btn = Instance.new("TextButton", tabHolder)
    btn.Size = UDim2.new(0, 70, 1, 0); btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    btn.Text = text; btn.TextColor3 = Color3.new(1, 1, 1); btn.Font = "GothamBold"; btn.TextSize = 10; btn.TextScaled = true
    Instance.new("UICorner", btn)
    applyClickAnimation(btn)
    btn.MouseButton1Click:Connect(function()
        for _, t in pairs(tabs) do t.Visible = false end
        targetTab.Visible = true
    end)
end

