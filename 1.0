local isMenuAnimating = false
local function toggleMenu()
    if isMenuAnimating then return end
    isMenuAnimating = true
    if not main.Visible then
        main.Size = UDim2.new(0, 0, 0, 0)
        main.Visible = true
        local tw = TweenService:Create(main, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, 280, 0, 320)})
        tw:Play()
        tw.Completed:Connect(function() isMenuAnimating = false end)
    else
        local tw = TweenService:Create(main, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0)})
        tw:Play()
        tw.Completed:Connect(function() main.Visible = false; isMenuAnimating = false end)
    end
end

