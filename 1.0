local function createFloatBtn(emoji, varName)
    local btn = Instance.new("TextButton", floatPanel)
    btn.Size = UDim2.new(0, 35, 0, 35)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    btn.Text = emoji
    btn.TextScaled = true
    Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0)

    btn.MouseButton1Click:Connect(function()
        getgenv()[varName] = not getgenv()[varName]
        btn.BackgroundColor3 = getgenv()[varName] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(30, 30, 30)
    end)
    
    RunService.RenderStepped:Connect(function()
        btn.BackgroundColor3 = getgenv()[varName] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(30, 30, 30)
    end)
end

createFloatBtn("🤺", "AutoAttack")
createFloatBtn("⚡", "TeleportOnAttack")
createFloatBtn("⚔️", "StickMode")

--// SISTEMA DE SLIDER E TOGGLE COM CALLBACK
local function createSlider(parent, text, min, max, default, varName)
    local sliderFrame = Instance.new("Frame", parent)
    sliderFrame.Size = UDim2.new(1, -10, 0, 50)
    sliderFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    Instance.new("UICorner", sliderFrame).CornerRadius = UDim.new(0, 6)

    local label = Instance.new("TextLabel", sliderFrame)
    label.Size = UDim2.new(1, 0, 0, 20)
    label.BackgroundTransparency = 1
    label.Text = text .. ": " .. default
    label.TextColor3 = Color3.new(1, 1, 1)
    label.Font = Enum.Font.GothamSemibold

    local bar = Instance.new("Frame", sliderFrame)
    bar.Size = UDim2.new(1, -20, 0, 6)
    bar.Position = UDim2.new(0, 10, 0, 30)
    bar.BackgroundColor3 = Color3.fromRGB(45, 45, 45)

    local fill = Instance.new("Frame", bar)
    fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(0, 200, 0)

    local function update(input)
        local pos = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
        fill.Size = UDim2.new(pos, 0, 1, 0)
        local value = math.floor(min + (max - min) * pos)
        getgenv()[varName] = value
        label.Text = text .. ": " .. value
    end

    bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            update(input)
            local move; move = UserInputService.InputChanged:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                    update(input)
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then move:Disconnect() end
            end)
        end
    end)
end

local function createToggle(parent, text, varName, isDefaultOn, callback)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1, -10, 0, 40)
    btn.BackgroundColor3 = (isDefaultOn and getgenv()[varName]) and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(30, 30, 30)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamBold
    btn.Text = text .. ((isDefaultOn and getgenv()[varName]) and " [ON]" or " [OFF]")
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

    btn.MouseButton1Click:Connect(function()
        getgenv()[varName] = not getgenv()[varName]
        btn.Text = text .. (getgenv()[varName] and " [ON]" or " [OFF]")
        btn.BackgroundColor3 = getgenv()[varName] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(30, 30, 30)
        if callback then callback(getgenv()[varName]) end
    end)
end

--// CONTEÚDO COMBATE
createToggle(combatTab, "Auto Attack", "AutoAttack")
createToggle(combatTab, "Teleport no Ataque", "TeleportOnAttack")
createToggle(combatTab, "Grudar no Alvo", "StickMode")
createSlider(combatTab, "Distância Grudar", 0, 15, 3, "StickDistance")
createSlider(combatTab, "Suavidade (Lag)", 0, 90, 0, "StickSmoothness")

--// CONTEÚDO LOCALPLAYER
createSlider(playerTab, "Velocidade (Speed)", 16, 150, 16, "WalkSpeedValue")
createToggle(playerTab, "Pulo Infinito", "InfiniteJump")
createToggle(playerTab, "Anti-Fling / Ragdoll", "AntiFling")
createToggle(playerTab, "Mostrar Painel ⚔️", "FloatingPanelVisible", true, function(state)
    floatPanel.Visible = state
end)

--// LOOPS DE FUNCIONAMENTO
RunService.Heartbeat:Connect(function()
    -- RGB
    local rgb = Color3.fromHSV(tick() % 5 / 5, 1, 1)
    title.TextColor3 = rgb
    mainStroke.Color = rgb
    floatStroke.Color = rgb

    -- WalkSpeed (Forçado de forma leve)
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = getgenv().WalkSpeedValue
    end

    -- Grudar (Com Suavidade e Distância ajustáveis)
    local target, dist = getClosest()
    if getgenv().StickMode and target and target.Character then
        local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        local eRoot = target.Character:FindFirstChild("HumanoidRootPart")
        if myRoot and eRoot then
            local goalCFrame = eRoot.CFrame * CFrame.new(0, 0, getgenv().StickDistance)
            local lerpVal = 1 - (getgenv().StickSmoothness / 100)
            myRoot.CFrame = myRoot.CFrame:Lerp(goalCFrame, lerpVal)
        end
    end

    -- Novo Anti-Fling / Anti-Ragdoll
    if getgenv().AntiFling and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        local hum = LocalPlayer.Character.Humanoid
        hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        
        -- Levanta instantaneamente se o jogo tentar te derrubar
        if hum:GetState() == Enum.HumanoidStateType.Ragdoll or hum:GetState() == Enum.HumanoidStateType.FallingDown then
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
        end
    end
end)

-- Pulo Infinito
UserInputService.JumpRequest:Connect(function()
    if getgenv().InfiniteJump and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid:ChangeState("Jumping")
    end
end)

-- Auto Attack
task.spawn(function()
    while true do
        if getgenv().AutoAttack then
            local target, dist = getClosest()
            if target and dist <= attackRange then
                local remote = getRemote()
                if remote then
                    remote:FireServer({Key = "TouchATK", State = Enum.UserInputState.Begin})
                    task.wait(0.05)
                    remote:FireServer({Key = "TouchATK", State = Enum.UserInputState.End})
                end
            end
        end
        task.wait(0.12)
    end
end)

-- Teleport no Ataque
task.spawn(function()
    while true do
        local pg = LocalPlayer:FindFirstChild("PlayerGui")
        local btn = pg and pg:FindFirstChild("MobileScr", true) and pg.MobileScr:FindFirstChild("ATK", true)
        if btn and not btn:FindFirstChild("TpHook") then
            Instance.new("BoolValue", btn).Name = "TpHook"
            btn.MouseButton1Down:Connect(function()
                if getgenv().TeleportOnAttack then
                    local target = getClosest()
                    if target and target.Character then
                        local myRoot = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                        local eRoot = target.Character:FindFirstChild("HumanoidRootPart")
                        if myRoot and eRoot then
                            myRoot.CFrame = eRoot.CFrame * CFrame.new(0, 0, getgenv().StickDistance)
                        end
                    end
                end
            end)
        end
        task.wait(1)
    end
end)

-- ESP / Highlight Loop
RunService.RenderStepped:Connect(function()
    local target = getClosest()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local hl = plr.Character:FindFirstChild("DW_Highlight") or Instance.new("Highlight", plr.Character)
            hl.Name = "DW_Highlight"
            hl.FillTransparency = 0.5
            if isWhitelisted(plr) then
                hl.FillColor = Color3.new(0, 1, 0)
                hl.Enabled = true
            elseif plr == target then
                hl.FillColor = Color3.new(1, 0, 0)
                hl.Enabled = true
            else
                hl.Enabled = false
            end
        end
    end
end)
