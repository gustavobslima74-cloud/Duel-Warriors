local oldLayout = Instance.new("UIListLayout", oldPanel); oldLayout.FillDirection = "Horizontal"; oldLayout.HorizontalAlignment = "Center"; oldLayout.VerticalAlignment = "Center"; oldLayout.Padding = UDim.new(0, 8)
