--// ABA WHITELIST (ORDEM ALFABÉTICA A-Z)
task.spawn(function()
    while true do
        if tabs.Whitelist.Visible then
            local currentPlayers = Players:GetPlayers()
            
            table.sort(currentPlayers, function(a, b)
                return a.DisplayName:lower() < b.DisplayName:lower()
            end)

            for _, v in pairs(tabs.Whitelist:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
            
            for _, p in pairs(currentPlayers) do
                if p ~= LocalPlayer then
                    local b = Instance.new("TextButton", tabs.Whitelist); b.Size = UDim2.new(1, 0, 0, 30)
                    b.Text = p.DisplayName; b.BackgroundColor3 = isWhitelisted(p) and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(40, 40, 40)
                    b.TextColor3 = Color3.new(1,1,1); b.Font = Enum.Font.Gotham; Instance.new("UICorner", b)
                    b.MouseButton1Click:Connect(function()
                        whitelist[p.UserId] = not whitelist[p.UserId]
                        b.BackgroundColor3 = whitelist[p.UserId] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(40, 40, 40)
                    end)
                end
            end
        end
        task.wait(4)
    end
end)

--// SISTEMA DE GESTO NATIVO
local touchStart = nil
UserInputService.TouchStarted:Connect(function(touch, gameProcessed) if not gameProcessed then touchStart = touch.Position end end)
UserInputService.TouchEnded:Connect(function(touch, gameProcessed)
    if not touchStart then return end
    local drop = touch.Position - touchStart; local screen = workspace.CurrentCamera.ViewportSize
    -- Se o deslize para baixo for maior que 80px e começar no terço superior da tela
    if drop.Y > 80 and math.abs(drop.X) < 60 and touchStart.Y < (screen.Y * 0.3) then
        main.Visible = not main.Visible
        if main.Visible then main.Position = UDim2.new(0.5, -140, 0.5, -160) end
    end
    touchStart = nil
end)

--// LOOPS PRINCIPAIS
RunService.Stepped:Connect(function()
    for varName, data in pairs(MenuToggles) do
        local state = getgenv()[varName]
        if data.Btn and data.Text then
            data.Btn.Text = data.Text .. (state and " [ON]" or " [OFF]")
            data.Btn.BackgroundColor3 = state and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(30, 30, 30)
        end
    end
    local rgb = Color3.fromHSV(tick() % 5 / 5, 1, 1)
    title.TextColor3 = rgb; mainStroke.Color = rgb; oldStroke.Color = rgb
    local isRec = getgenv().RecordingMode
    
    oldPanel.BackgroundTransparency = isRec and 1 or 0; oldStroke.Transparency = isRec and 1 or 0; moveHandle.Visible = not isRec
    for _, data in pairs(OldPanelBtns) do data.Btn.BackgroundTransparency = isRec and 1 or 0; data.Btn.TextTransparency = isRec and 1 or 0; if not isRec then data.Btn.BackgroundColor3 = getgenv()[data.Var] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(30, 30, 30) end end
    for varName, data in pairs(ActiveFloatingButtons) do data.Frame.BackgroundTransparency = isRec and 1 or 0; data.Btn.TextTransparency = isRec and 1 or 0; local x = data.Frame:FindFirstChildOfClass("TextButton"); if x then x.Visible = not isRec end; if not isRec then data.Frame.BackgroundColor3 = getgenv()[varName] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(20, 20, 20) end end
    local char = LocalPlayer.Character; local hum = char and char:FindFirstChild("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if hum then hum.WalkSpeed = getgenv().WalkSpeedValue end
    local target, dist = getClosest(); local eRoot = target and target.Character and target.Character:FindFirstChild("HumanoidRootPart")
    if getgenv().StickMode and root and eRoot then root.CFrame = root.CFrame:Lerp(eRoot.CFrame * CFrame.new(0, 0, getgenv().StickDistance), 1 - (getgenv().StickSmoothness/100)) end
    
    if getgenv().CharAimLock and root and eRoot and dist <= getgenv().AimbotRange then
        local bg = root:FindFirstChild("DW_AimGyro") or Instance.new("BodyGyro", root); bg.Name = "DW_AimGyro"; bg.MaxTorque = Vector3.new(0, math.huge, 0); bg.P = 500000
        bg.CFrame = CFrame.lookAt(root.Position, Vector3.new(eRoot.Position.X, root.Position.Y, eRoot.Position.Z))
    elseif root and root:FindFirstChild("DW_AimGyro") then root.DW_AimGyro:Destroy() end
    
    if getgenv().MyHealth and hum then myHealthLbl.Visible = true; myHealthLbl.Text = "MEU HP: "..math.floor(hum.Health).." / "..math.floor(hum.MaxHealth); myHealthLbl.TextColor3 = hum.Health > (hum.MaxHealth*0.6) and Color3.new(0,1,0) or (hum.Health > (hum.MaxHealth*0.3) and Color3.new(1,1,0) or Color3.new(1,0,0)) else myHealthLbl.Visible = false end
    if getgenv().AntiFling and hum then hum:SetStateEnabled(10, false); hum:SetStateEnabled(1, false); if hum:GetState() == Enum.HumanoidStateType.Ragdoll then hum:ChangeState(Enum.HumanoidStateType.GettingUp) end end
end)

UserInputService.JumpRequest:Connect(function() if getgenv().InfiniteJump and LocalPlayer.Character:FindFirstChild("Humanoid") then LocalPlayer.Character.Humanoid:ChangeState(3) end end)

task.spawn(function()
    while true do
        if getgenv().AutoAttack then
            local t, d = getClosest()
            if t and d <= getgenv().AttackRange then 
                local r = getRemote(); if r then r:FireServer({Key = "TouchATK", State = Enum.UserInputState.Begin}); task.wait(0.05); r:FireServer({Key = "TouchATK", State = Enum.UserInputState.End}) end 
            end
        end
        task.wait(0.1)
    end
end)

task.spawn(function()
    while true do
        local b = LocalPlayer.PlayerGui:FindFirstChild("ATK", true)
        if b and b:IsA("GuiButton") and not b:FindFirstChild("TpHook") then
            Instance.new("BoolValue", b).Name = "TpHook"
            b.MouseButton1Down:Connect(function() if getgenv().TeleportOnAttack then local t = getClosest(); if t and t.Character then LocalPlayer.Character.HumanoidRootPart.CFrame = t.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, getgenv().StickDistance) end end end)
        end
        task.wait(1)
    end
end)

RunService.RenderStepped:Connect(function()
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local target = getClosest(); local plrsDist = {}
    if myRoot then
        for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then table.insert(plrsDist, {plr = p, dist = (myRoot.Position - p.Character.HumanoidRootPart.Position).Magnitude}) end end
        table.sort(plrsDist, function(a,b) return a.dist < b.dist end)
    end
    local top5 = {}; for i=1, math.min(5, #plrsDist) do top5[plrsDist[i].plr] = true end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hl = p.Character:FindFirstChild("DW_Highlight") or Instance.new("Highlight", p.Character); hl.Name = "DW_Highlight"; hl.FillTransparency = 0.5
            if isWhitelisted(p) and getgenv().HighlightFriendly then hl.FillColor = Color3.new(0,1,0); hl.Enabled = true
            elseif p == target and getgenv().HighlightEnemy then hl.FillColor = Color3.new(1,0,0); hl.Enabled = true
            else hl.Enabled = false end
            local bb = p.Character.HumanoidRootPart:FindFirstChild("DW_HealthESP")
            if getgenv().HealthESP and top5[p] then
                if not bb then bb = Instance.new("BillboardGui", p.Character.HumanoidRootPart); bb.Name = "DW_HealthESP"; bb.Size = UDim2.new(0, 80, 0, 30); bb.StudsOffset = Vector3.new(2.5, -1.5, 0); bb.AlwaysOnTop = true; local t = Instance.new("TextLabel", bb); t.Size = UDim2.new(1,0,1,0); t.BackgroundTransparency = 1; t.Font = "GothamBold"; t.TextSize = 11; t.TextStrokeTransparency = 0 end
                local h = math.floor(p.Character.Humanoid.Health); local m = math.floor(p.Character.Humanoid.MaxHealth); bb.TextLabel.Text = h.." / "..m; bb.TextLabel.TextColor3 = h > (m*0.6) and Color3.new(0,1,0) or (h > (m*0.3) and Color3.new(1,1,0) or Color3.new(1,0,0))
            elseif bb then bb:Destroy() end
        end
    end
end)
