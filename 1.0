--// SERVICES
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local LocalPlayer = Players.LocalPlayer

--// VARS GLOBAIS
getgenv().AutoAttack = false
getgenv().StickMode = false
getgenv().TeleportOnAttack = false
getgenv().FloatingPanelVisible = false

local whitelist = {}
local attackRange = 15 -- Distância máxima para o Auto Attack

--// REMOVE VERSÃO ANTIGA (Evita duplicatas)
if CoreGui:FindFirstChild("DuelWarriorsUI") then
    CoreGui.DuelWarriorsUI:Destroy()
end

--// FUNÇÕES CORE
local function getRemote()
    local charFolder = workspace:FindFirstChild("Player")
    if not charFolder then return end
    local plrFolder = charFolder:FindFirstChild(LocalPlayer.Name)
    if not plrFolder then return end
    return plrFolder:FindFirstChild("Communicate")
end

local function isWhitelisted(plr)
    return whitelist[plr.UserId] == true
end

local function getClosest()
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil, math.huge end

    local closest = nil
    local dist = math.huge

    for _,plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and not isWhitelisted(plr) and plr.Character then
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
            local hum = plr.Character:FindFirstChild("Humanoid")

            if root and hum and hum.Health > 0 then
                local d = (myRoot.Position - root.Position).Magnitude
                if d < dist then
                    dist = d
                    closest = plr
                end
            end
        end
    end
    return closest, dist
end

--// GUI SETUP
local gui = Instance.new("ScreenGui")
gui.Name = "DuelWarriorsUI"
gui.ResetOnSpawn = false
gui.Parent = CoreGui

-- FUNÇÃO DE ARRASTAR
local function makeDraggable(guiObject)
    local dragging, dragInput, dragStart, startPos

    guiObject.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = guiObject.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    guiObject.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    RunService.RenderStepped:Connect(function()
        if dragging and dragInput then
            local delta = dragInput.Position - dragStart
            guiObject.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

--// BOTÃO DE ABRIR/FECHAR MENU
