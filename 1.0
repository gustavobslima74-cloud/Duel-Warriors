--// SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local StarterGui = game:GetService("StarterGui")

--// VARS
getgenv().DebugHits = true

--// FUNÇÃO DE NOTIFICAÇÃO
local function notify(title, text)
    StarterGui:SetCore("SendNotification", {
        Title = title,
        Text = text,
        Duration = 3
    })
end

--// PROCURANDO O REMOTE DE COMUNICAÇÃO
-- Baseado no seu script anterior, o remote fica em workspace.Player.Nome.Communicate
local function getCommRemote()
    local charFolder = workspace:FindFirstChild("Player")
    local plrFolder = charFolder and charFolder:FindFirstChild(LocalPlayer.Name)
    return plrFolder and plrFolder:FindFirstChild("Communicate")
end

--// 1. DETECTAR HITS (MONITORANDO O REMOTE)
-- Aqui vamos interceptar quando você envia um sinal de ataque e ver se o jogo responde
local mt = getrawmetatable(game)
local old = mt.__namecall
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if method == "FireServer" and self.Name == "Communicate" then
        -- Se o argumento possuir algo relacionado a Hit ou Dano
        if args[1] and (args[1].Key == "TouchATK" or args[1].Type == "Hit") then
            if getgenv().DebugHits then
                warn("--- HIT LOCALIZADO ---")
                print("Argumentos enviados:", game:GetService("HttpService"):JSONEncode(args[1]))
                notify("Combo Debug", "HIT LOCALIZADO! Cheque o Console (F9)")
            end
        end
    end
    return old(self, ...)
end)

setreadonly(mt, true)

--// 2. CRIAÇÃO DA UI DE TESTE (SIMPLES)
local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
local Frame = Instance.new("Frame", ScreenGui)
Frame.Size = UDim2.new(0, 200, 0, 150)
Frame.Position = UDim2.new(0.8, 0, 0.5, 0)
Frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)

local layout = Instance.new("UIListLayout", Frame)
layout.Padding = UDim.new(0, 5)

local function createTestBtn(text, callback)
    local btn = Instance.new("TextButton", Frame)
    btn.Size = UDim2.new(1, 0, 0, 40)
    btn.Text = text
    btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.MouseButton1Click:Connect(callback)
end

--// BOTÃO TESTAR ROLL
createTestBtn("Testar ROLL (Desviar)", function()
    local r = getCommRemote()
    if r then
        -- Tentando disparar o Roll. Geralmente jogos usam "Roll", "Dash" ou "Dodge"
        r:FireServer({Key = "Roll", State = Enum.UserInputState.Begin})
        task.wait(0.1)
        r:FireServer({Key = "Roll", State = Enum.UserInputState.End})
        notify("Teste", "Sinal de Roll enviado!")
    else
        notify("Erro", "Remote não encontrado!")
    end
end)

--// BOTÃO LIMPAR CONSOLE
createTestBtn("Limpar Log", function()
    print("\126") -- Limpa o console interno
    notify("Debug", "Log limpo.")
end)

notify("Auto Combo Debug", "Script de teste carregado!")
