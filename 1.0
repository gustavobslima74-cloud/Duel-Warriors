--// CONSTRUTORES DE UI
local function createToggle(parent, text, varName, callback)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1, -5, 0, 38); btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    local isGlobal = getgenv()[varName] ~= nil
    local currentState = isGlobal and getgenv()[varName] or false
    btn.Text = text .. (currentState and " [ON]" or " [OFF]"); btn.TextColor3 = Color3.new(1,1,1); btn.Font = "GothamBold"
    Instance.new("UICorner", btn)
    applyClickAnimation(btn)
    MenuToggles[varName] = {Btn = btn, Text = text}
    btn.MouseButton1Click:Connect(function()
        if isGlobal then getgenv()[varName] = not getgenv()[varName] end
        local newState = isGlobal and getgenv()[varName] or not currentState
        if not isGlobal then currentState = newState end
        if callback then callback(newState, btn) end
    end)
end

local function createSlider(parent, text, min, max, default, varName)
    local frame = Instance.new("Frame", parent); frame.Size = UDim2.new(1, -5, 0, 45); frame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    Instance.new("UICorner", frame)
    local lbl = Instance.new("TextLabel", frame); lbl.Size = UDim2.new(1, 0, 0, 20); lbl.Text = text..": "..default; lbl.TextColor3 = Color3.new(1,1,1); lbl.BackgroundTransparency = 1
    local bar = Instance.new("Frame", frame); bar.Size = UDim2.new(1, -20, 0, 5); bar.Position = UDim2.new(0, 10, 0, 30); bar.BackgroundColor3 = Color3.fromRGB(50,50,50)
    local fill = Instance.new("Frame", bar); fill.Size = UDim2.new((default-min)/(max-min), 0, 1, 0); fill.BackgroundColor3 = Color3.fromRGB(0,200,0)
    bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            local function move()
                local pos = math.clamp((UserInputService:GetMouseLocation().X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                fill.Size = UDim2.new(pos, 0, 1, 0)
                local val = math.floor(min + (max-min)*pos)
                getgenv()[varName] = val; lbl.Text = text..": "..val
            end
            local con; con = RunService.RenderStepped:Connect(move)
            UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then con:Disconnect() end end)
        end
    end)
end

local function createStepper(parent, text, varName, step)
    local frame = Instance.new("Frame", parent)
    frame.Size = UDim2.new(1, -5, 0, 45)
    frame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    Instance.new("UICorner", frame)

    local lbl = Instance.new("TextLabel", frame)
    lbl.Size = UDim2.new(1, -80, 1, 0); lbl.Position = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1; lbl.Text = text .. ": " .. getgenv()[varName]
    lbl.TextColor3 = Color3.new(1, 1, 1); lbl.Font = Enum.Font.GothamBold; lbl.TextXAlignment = Enum.TextXAlignment.Left

    local minusBtn = Instance.new("TextButton", frame)
    minusBtn.Size = UDim2.new(0, 30, 0, 30); minusBtn.Position = UDim2.new(1, -75, 0.5, -15)
    minusBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40); minusBtn.Text = "-"; minusBtn.TextColor3 = Color3.new(1, 1, 1); minusBtn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", minusBtn); applyClickAnimation(minusBtn)

    local plusBtn = Instance.new("TextButton", frame)
    plusBtn.Size = UDim2.new(0, 30, 0, 30); plusBtn.Position = UDim2.new(1, -35, 0.5, -15)
    plusBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40); plusBtn.Text = "+"; plusBtn.TextColor3 = Color3.new(1, 1, 1); plusBtn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", plusBtn); applyClickAnimation(plusBtn)

    minusBtn.MouseButton1Click:Connect(function()
        getgenv()[varName] = math.max(0, getgenv()[varName] - step)
        lbl.Text = text .. ": " .. getgenv()[varName]
    end)

    plusBtn.MouseButton1Click:Connect(function()
        getgenv()[varName] = getgenv()[varName] + step
        lbl.Text = text .. ": " .. getgenv()[varName]
    end)
end

-- Novo Sistema de Dropdown (Pasta)
local function createDropdownFolder(parent, text)
    local container = Instance.new("Frame", parent)
    container.Size = UDim2.new(1, -5, 0, 0)
    container.AutomaticSize = Enum.AutomaticSize.Y
    container.BackgroundTransparency = 1
    
    local containerLayout = Instance.new("UIListLayout", container)
    containerLayout.SortOrder = Enum.SortOrder.LayoutOrder
    containerLayout.Padding = UDim.new(0, 5)

    local isOpen = false 

    local folderBtn = Instance.new("TextButton", container)
    folderBtn.Size = UDim2.new(1, 0, 0, 35)
    folderBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    folderBtn.Text = "▶ " .. text 
    folderBtn.TextColor3 = Color3.new(1, 1, 1)
    folderBtn.Font = Enum.Font.GothamBlack
    Instance.new("UICorner", folderBtn)
    applyClickAnimation(folderBtn)

    local contentFrame = Instance.new("Frame", container)
    contentFrame.Size = UDim2.new(1, 0, 0, 0) 
    contentFrame.BackgroundTransparency = 1
    contentFrame.ClipsDescendants = true

    local contentLayout = Instance.new("UIListLayout", contentFrame)
    contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
    contentLayout.Padding = UDim.new(0, 5)

    contentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        if isOpen then
            contentFrame.Size = UDim2.new(1, 0, 0, contentLayout.AbsoluteContentSize.Y)
        end
    end)

    folderBtn.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        folderBtn.Text = (isOpen and "▼ " or "▶ ") .. text
        if isOpen then
            TweenService:Create(contentFrame, TweenInfo.new(0.3), {Size = UDim2.new(1, 0, 0, contentLayout.AbsoluteContentSize.Y)}):Play()
        else
            TweenService:Create(contentFrame, TweenInfo.new(0.3), {Size = UDim2.new(1, 0, 0, 0)}):Play()
        end
    end)

    return contentFrame
end

