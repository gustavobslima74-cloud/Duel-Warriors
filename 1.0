local function createFloatBtn(emoji, varName)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(0, 35, 0, 35); b.Text = emoji; b.TextScaled = true; b.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Instance.new("UICorner", b, {CornerRadius = UDim.new(1, 0)})
    Instance.new("UIAspectRatioConstraint", b, {AspectRatio = 1})
    makeDraggable(b)
    table.insert(FloatingButtonsList, b); b.Parent = floatPanel
    b.MouseButton1Click:Connect(function() getgenv()[varName] = not getgenv()[varName] end)
end

