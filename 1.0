--// SERVICES
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local HttpService = game:GetService("HttpService") -- Serviço necessário para o JSON
local LocalPlayer = Players.LocalPlayer

--// REMOVE ANTIGO
if CoreGui:FindFirstChild("ComboDebugUI") then CoreGui.ComboDebugUI:Destroy() end

--// INTERFACE
local gui = Instance.new("ScreenGui", CoreGui)
gui.Name = "ComboDebugUI"

local toggleBtn = Instance.new("TextButton", gui)
toggleBtn.Size = UDim2.new(0, 50, 0, 50); toggleBtn.Position = UDim2.new(0, 10, 0.5, -25)
toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 255); toggleBtn.Text = "MENU"
toggleBtn.TextColor3 = Color3.new(1, 1, 1); toggleBtn.Font = "GothamBold"
Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(1, 0)

local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0, 260, 0, 320); main.AnchorPoint = Vector2.new(0.5, 0.5)
main.Position = UDim2.new(0.5, 0, 0.5, 0); main.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
main.Visible = false; Instance.new("UICorner", main)
local stroke = Instance.new("UIStroke", main); stroke.Color = Color3.fromRGB(0, 170, 255); stroke.Thickness = 2

-- Arrastar e Abrir
toggleBtn.MouseButton1Click:Connect(function() 
    main.Visible = not main.Visible 
    if main.Visible then main.Position = UDim2.new(0.5, 0, 0.5, 0) end
end)

local container = Instance.new("ScrollingFrame", main)
container.Size = UDim2.new(1, -10, 1, -50); container.Position = UDim2.new(0, 5, 0, 45)
container.BackgroundTransparency = 1; local layout = Instance.new("UIListLayout", container); layout.Padding = UDim.new(0, 5)

local function createBtn(text, color, callback)
    local btn = Instance.new("TextButton", container)
    btn.Size = UDim2.new(1, -5, 0, 40); btn.BackgroundColor3 = color; btn.Text = text
    btn.TextColor3 = Color3.new(1,1,1); btn.Font = "GothamMedium"; Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(callback)
end

-- BOTÕES
createBtn("📡 ATIVAR LOGGER (F9)", Color3.fromRGB(60, 60, 60), function()
    getgenv().LogRemotes = not getgenv().LogRemotes
    print("--- LOGGER: " .. (getgenv().LogRemotes and "ON" or "OFF"))
end)

createBtn("🌪️ TESTAR ROLL", Color3.fromRGB(0, 100, 200), function()
    local r = workspace:FindFirstChild("Player") and workspace.Player:FindFirstChild(LocalPlayer.Name) and workspace.Player[LocalPlayer.Name]:FindFirstChild("Communicate")
    if r then r:FireServer({Key = "Roll", State = Enum.UserInputState.Begin}) end
end)

createBtn("🧹 LIMPAR CONSOLE", Color3.fromRGB(150, 0, 0), function()
    print("\126")
end)

--// LÓGICA DE HIT PRÓPRIO
local enemyHealth = {}
local MAX_HIT_DISTANCE = 18

RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character:FindFirstChild("HumanoidRootPart") then
            local h = p.Character.Humanoid
            local targetRoot = p.Character.HumanoidRootPart
            
            if enemyHealth[p.UserId] and h.Health < enemyHealth[p.UserId] then
                local dist = (root.Position - targetRoot.Position).Magnitude
                if dist <= MAX_HIT_DISTANCE then
                    warn("🎯 MEU HIT DETECTADO! Alvo: " .. p.DisplayName)
                end
            end
            enemyHealth[p.UserId] = h.Health
        end
    end
end)

--// HOOK CORRIGIDO
local old; old = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    
    if getgenv().LogRemotes and method == "FireServer" and self.Name == "Communicate" then
        local data = args[1]
        
        -- Filtro para não spammar movimentos de CFrame ou valores nulos
        if type(data) == "table" and data.Key and not tostring(data.Key):find("CF") then
            -- Correção do JSONEncode (estava escrito errado antes)
            local success, result = pcall(function() return HttpService:JSONEncode(data) end)
            if success then
                warn("CAPTURA: " .. result)
            end
        end
    end
    return old(self, ...)
end)
