local function spawnFloatingBtn(emoji, varName)
    if ActiveFloatingButtons[varName] then return end 
    local frame = Instance.new("Frame", gui); frame.Size = UDim2.new(0, 32, 0, 32); frame.Position = UDim2.new(0.5, math.random(-80, 80), 0.5, math.random(-80, 80))
    frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20); Instance.new("UICorner", frame, {CornerRadius = UDim.new(1, 0)})
    Instance.new("UIAspectRatioConstraint", frame, {AspectRatio = 1})
    local btn = Instance.new("TextButton", frame); btn.Size = UDim2.new(1, 0, 1, 0); btn.BackgroundTransparency = 1; btn.Text = emoji; btn.TextScaled = true
    Instance.new("UICorner", btn, {CornerRadius = UDim.new(1, 0)}); makeDraggable(frame, btn); applyClickAnimation(btn)
    local xBtn = Instance.new("TextButton", frame); xBtn.Size = UDim2.new(0, 14, 0, 14); xBtn.Position = UDim2.new(1, -8, 0, -5)
    xBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0); xBtn.Text = "X"; xBtn.TextColor3 = Color3.new(1,1,1); xBtn.Font = Enum.Font.GothamBold; xBtn.TextScaled = true
    Instance.new("UICorner", xBtn, {CornerRadius = UDim.new(1, 0)}); applyClickAnimation(xBtn)
    btn.MouseButton1Click:Connect(function() getgenv()[varName] = not getgenv()[varName] end)
    xBtn.MouseButton1Click:Connect(function() frame:Destroy() ActiveFloatingButtons[varName] = nil end)
    ActiveFloatingButtons[varName] = {Frame = frame, Btn = btn}
end

